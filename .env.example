# FerrumGate configuration
FERRUMGATE_BIND_ADDR=0.0.0.0:8080
FERRUMGATE_TLS_CERT_PATH=/etc/ssl/certs/cert.pem
FERRUMGATE_TLS_KEY_PATH=/etc/ssl/private/key.pem
FERRUMGATE_UPSTREAM_URL=http://backend:3000
FERRUMGATE_LOG_LEVEL=info
FERRUMGATE_AUTH_SECRET=your_jwt_secret_here
FERRUMGATE_RATE_LIMIT_RPS=1000
